{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:rag\"",
    "dev:server": "nodemon",
    "dev:rag": "cd RAG && ./venv/bin/uvicorn api:app --host 0.0.0.0 --port 8000 --reload",
    "start": "tsx index.ts"
  },
  "nodemonConfig": {
    "exec": "tsx index.ts",
    "ext": "ts,json",
    "ignore": [
      "node_modules",
      "uploads",
      "logs",
      "RAG"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
