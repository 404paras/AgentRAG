# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/docpal

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# API Keys Encryption (used to encrypt user-supplied API keys stored in MongoDB)
API_KEY_ENCRYPTION_SECRET=your-32-character-encryption-key!

# Frontend URL (for CORS)
CORS_ORIGIN=http://localhost:5173

# Pinecone Configuration
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=agentrag-notes

# ============ AI / SEARCH KEYS (server-level fallbacks) ============
# At least one LLM key (Groq or Gemini) is required for chat to work.
# Users can also supply their own keys via the Settings page (stored encrypted).

# Groq API (primary LLM - llama-3.3-70b-versatile)
# Free tier available - https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Google Gemini API (fallback LLM + embeddings)
# Free tier available - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# HuggingFace API (fallback embedding provider)
# Free tier available - https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Serper API (web search fallback via CrewAI)
# 2,500 free searches/month - https://serper.dev
SERPER_API_KEY=your-serper-api-key-here

# Python RAG Service URL
RAG_SERVICE_URL=http://localhost:8000

# Logging
LOG_LEVEL=info
